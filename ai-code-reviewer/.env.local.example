# This is a template for local development
# Copy this to .env in the backend and ai-agent directories

# Backend Configuration
DATABASE_URL=sqlite:///./code_reviews.db
SECRET_KEY=dev-secret-key-change-in-production
AI_AGENT_URL=http://localhost:8001
AI_AGENT_API_KEY=dev-api-key
RATE_LIMIT_PER_HOUR=10

# AI Agent Configuration
GROQ_API_KEY=your-groq-api-key-here-or-leave-blank-for-mock-mode
AI_AGENT_API_KEY=dev-api-key

# Frontend Configuration (optional)
VITE_API_URL=http://localhost:8000
